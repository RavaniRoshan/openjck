{
  "name": "openjck",
  "version": "0.2.1",
  "description": "Visual debugger for AI agent loops. Step-by-step. Locally. Zero config.",
  "type": "module",
  "bin": {
    "openjck": "bin/openjck.js"
  },
  "main": "./src/server.js",
  "scripts": {
    "start": "node bin/openjck.js ui",
    "build:ui": "cd dashboard && npm install && npm run build",
    "prepublishOnly": "npm run build:ui"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "debugging",
    "observability",
    "langchain",
    "crewai",
    "autogen",
    "ollama",
    "tracing",
    "openai",
    "anthropic",
    "devtools"
  ],
  "homepage": "https://openjck.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RavaniRoshan/openjck.git"
  },
  "bugs": {
    "url": "https://github.com/RavaniRoshan/openjck/issues"
  },
  "author": "OpenJCK Contributors",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "express": "^4.18.2",
    "figlet": "^1.11.0",
    "open": "^10.1.0",
    "ora": "^8.0.1"
  }
}
