---
import BaseHead from '../components/BaseHead.astro';

const steps = [
  {
    id: "instrument",
    nav: "Instrument",
    title: "Add 3 decorators. That's it.",
    body: "No config files. No setup. No SDK to learn. Wrap your entry point, your LLM calls, and your tools. OpenJCK does the rest.",
    code: `from openjck import trace, trace_llm, trace_tool\n\n@trace(name="my_agent")\ndef run(): ...\n\n@trace_llm\ndef call_llm(messages): ...`,
    color: "#C99E5C", /* Golden Brown */
    darkSnippet: false
  },
  {
    id: "run",
    nav: "Run",
    title: "Run your agent. Same as always.",
    body: "No wrapper scripts. No extra commands. python my_agent.py — and OpenJCK captures everything silently in the background.",
    code: `$ python my_agent.py\n[OpenJCK] Run complete → COMPLETED\n[OpenJCK] 8 steps  |  2840 tokens  |  4.2s\n[OpenJCK] → http://localhost:7823/trace/a3f9c1b2`,
    color: "#C8A2E3", /* Lilac Purple */
    darkSnippet: false
  },
  {
    id: "inspect",
    nav: "Inspect",
    title: "See every step visually.",
    body: "Open the trace viewer and see your entire agent run laid out step by step. Every LLM call, every tool call, every decision.",
    code: `$ npx openjck\n→ Opening OpenJCK at localhost:7823\n\n● ── ● ── ● ── ● ── ● ── ● ── ● ── ✕\n1    2    3    4    5    6    7    8`,
    color: "#5C824E", /* Forest Green */
    darkSnippet: true
  },
  {
    id: "pinpoint",
    nav: "Pinpoint",
    title: "Find the exact step that broke.",
    body: "The timeline highlights failures in red. Click any step. See the full input, output, error traceback, and token count.",
    code: `STEP 8 — write_file     [FAILED]    12ms\n─────────────────────────────────────\nERROR\nPermissionError: cannot write to output.md\nFile is open in another process\nLine 47 in tools.py`,
    color: "#1887E4", /* Bright Blue */
    darkSnippet: false
  },
  {
    id: "fix",
    nav: "Fix",
    title: "Fix with full context.",
    body: "You know exactly what failed, why it failed, and what the agent was trying to do. Fix the bug with all the context you need.",
    code: `# Before: file was locked by another process\n# OpenJCK showed: output.md opened at step 3\n\n@trace_tool\ndef write_file(path: str, content: str):\n    with open(path, 'w') as f:  # ← fixed\n        f.write(content)`,
    color: "#FF7B54", /* Coral Orange */
    darkSnippet: false
  },
  {
    id: "ship",
    nav: "Ship",
    title: "Ship faster. Debug less.",
    body: "Re-run your agent. Watch the timeline go green. Every trace is saved locally — compare runs and ship with confidence.",
    code: `$ python my_agent.py\n[OpenJCK] Run complete → COMPLETED\n[OpenJCK] 9 steps  |  2840 tokens  |  3.8s\n✓ All steps passed`,
    color: "#A2AD39", /* Olive Green */
    darkSnippet: true
  }
];
---

<html lang="en">
<head>
  <BaseHead
    title="OpenJCK — Visual debugger for AI agent loops"
    description="Your agent ran 15 steps. Step 9 failed silently. OpenJCK shows you exactly what happened — every LLM call, every tool, every token."
  />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    /* ═══════════════════════════════════════════════════
       DESIGN SYSTEM (Ditto-Inspired)
       ═══════════════════════════════════════════════════ */
    :root {
      --bg-page:        #FAF9F6;  /* Warm off-white */
      --bg-dark:        #0A0A0A;  /* True black/dark */
      
      --brand-yellow:   #FFD600;  /* Vibrant Yellow */
      --brand-orange:   #FF6644;  /* Salmon / Orange */
      --brand-blue:     #2255FF;  /* Intense Blue highlight */
      --brand-purple:   #9955FF;  

      --text-main:      #0A0A0A;
      --text-inverse:   #FFFFFF;
      --text-muted:     #666666;

      --border-light:   #E5E5E5;
      --border-dark:    #333333;

      --font-display:   'Space Grotesk', sans-serif;
      --font-body:      'Inter', sans-serif;
      --font-mono:      'JetBrains Mono', monospace;
    }

    /* Resets */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.5;
      color: var(--text-main);
      background: var(--bg-page);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 32px;
    }

    /* Utilities */
    .font-display { font-family: var(--font-display); }
    .font-body { font-family: var(--font-body); }
    .font-mono { font-family: var(--font-mono); }
    .text-center { text-align: center; }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 28px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 15px;
      transition: all 0.2s ease;
      cursor: pointer;
      border: 2px solid transparent;
      font-family: var(--font-display);
    }
    .btn-dark {
      background: var(--text-main);
      color: var(--text-inverse);
    }
    .btn-dark:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 14px rgba(0,0,0,0.15);
    }
    .btn-outline {
      background: transparent;
      color: var(--text-main);
      border-color: var(--border-light);
    }
    .btn-outline:hover {
      border-color: var(--text-main);
    }

    /* ═══════════════════════════════════════════════════
       1. TOP BANNER
       ═══════════════════════════════════════════════════ */
    .top-banner {
      background: var(--brand-yellow);
      color: var(--text-main);
      text-align: center;
      font-weight: 500;
      font-size: 13px;
      padding: 10px 16px;
      border-bottom: 1px solid rgba(0,0,0,0.1);
    }
    .top-banner span {
      font-family: var(--font-mono);
      font-weight: 600;
      margin-left: 8px;
      display: inline-block;
    }

    /* ═══════════════════════════════════════════════════
       2. NAV
       ═══════════════════════════════════════════════════ */
    .nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(250, 249, 246, 0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid transparent;
      transition: border-color 0.3s ease;
    }
    .nav.scrolled {
      border-bottom-color: var(--border-light);
    }
    .nav__inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 80px;
    }
    .nav__logo {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 24px;
      letter-spacing: -0.04em;
    }
    .nav__links {
      display: flex;
      gap: 36px;
      font-weight: 500;
      font-size: 15px;
    }
    .nav__links a:hover {
      color: var(--brand-blue);
    }
    .nav__actions {
      display: flex;
      gap: 16px;
    }

    /* ═══════════════════════════════════════════════════
       3. HERO
       ═══════════════════════════════════════════════════ */
    .hero {
      padding: 120px 0 80px;
    }
    .hero__inner {
      display: flex;
      align-items: flex-end;
      gap: 60px;
    }
    .hero__left {
      flex: 1.5;
    }
    .hero__left h1 {
      font-family: var(--font-display);
      font-size: clamp(4rem, 8vw, 6.5rem);
      line-height: 0.95;
      font-weight: 700;
      letter-spacing: -0.05em;
      margin: 0;
    }
    .hero__highlight {
      background: var(--brand-blue);
      color: var(--text-inverse);
      display: inline-block;
      padding: 0 16px;
      border-radius: 8px;
      transform: rotate(-1deg);
      margin-top: 8px;
    }
    .hero__right {
      flex: 1;
      padding-bottom: 16px;
    }
    .hero__right p {
      font-size: 1.125rem;
      color: var(--text-muted);
      line-height: 1.6;
      margin-bottom: 32px;
      max-width: 440px;
    }
    .hero__ctas {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    /* ═══════════════════════════════════════════════════
       3.5 LATEST UPDATES BANNER
       ═══════════════════════════════════════════════════ */
    .updates-sec {
      border-top: 1px solid var(--border-light);
      background: #FAFAFA;
      padding: 16px 0;
    }
    .updates__inner {
      display: flex;
      align-items: center;
      gap: 20px;
    }
    .updates-badge {
      background: var(--brand-purple);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 4px 10px;
      border-radius: 999px;
    }
    .updates-content {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .updates-content h3 {
      font-size: 15px;
      font-weight: 700;
      margin: 0;
    }
    .updates-content p {
      font-size: 14px;
      color: var(--text-muted);
      margin: 0;
    }
    .updates-btn {
      font-size: 13px;
      padding: 6px 16px;
      border-radius: 999px;
      border: 1px solid var(--border-light);
      background: #fff;
      font-weight: 600;
      color: var(--text-main);
      transition: all 0.2s;
    }
    .updates-btn:hover {
      border-color: var(--text-main);
      background: var(--text-main);
      color: #fff;
    }

    /* ═══════════════════════════════════════════════════
       4. LOGOS
       ═══════════════════════════════════════════════════ */
    .logos {
      padding: 60px 0;
      border-top: 1px solid var(--border-light);
      border-bottom: 1px solid var(--border-light);
      text-align: center;
    }
    .logos__title {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      font-weight: 600;
      margin-bottom: 36px;
    }
    .logos__track {
      display: flex;
      justify-content: center;
      gap: 60px;
      flex-wrap: wrap;
    }
    .logo-item {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 700;
      color: #bbbbbb;
      letter-spacing: -0.02em;
    }

    /* ═══════════════════════════════════════════════════
       5. TRANSITION HEADING
       ═══════════════════════════════════════════════════ */
    .transition-sec {
      padding: 140px 0 80px;
      text-align: center;
    }
    .transition-sec h2 {
      font-family: var(--font-display);
      font-size: clamp(3rem, 5vw, 4.5rem);
      font-weight: 700;
      letter-spacing: -0.04em;
      margin: 0;
    }
    .transition-sec .highlight {
      background: var(--brand-yellow);
      display: inline-block;
      padding: 0 16px;
      border-radius: 8px;
    }

    /* ═══════════════════════════════════════════════════
       6. STICKY FEATURES
       ═══════════════════════════════════════════════════ */
    .features {
      padding: 0 0 140px;
    }
    .features__inner {
      display: flex;
      gap: 100px;
    }
    .features__nav {
      width: 250px;
      position: sticky;
      top: 140px;
      height: max-content;
    }
    .features__nav ul {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .features__nav a {
      display: flex;
      align-items: center;
      font-size: 16px;
      font-weight: 500;
      color: var(--text-muted);
      opacity: 0.5;
      transition: all 0.3s ease;
    }
    .features__nav a::before {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: currentColor;
      margin-right: 16px;
      opacity: 0;
      transform: scale(0);
      transition: all 0.3s ease;
    }
    .features__nav a.active {
      color: var(--text-main);
      opacity: 1;
      font-weight: 700;
    }
    .features__nav a.active::before {
      opacity: 1;
      transform: scale(1);
    }
    
    .features__content {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 140px;
    }
    .feature-card {
      border-radius: 24px;
      padding: 60px 48px;
      min-height: 500px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
    }
    .feature-card h3 {
      font-family: var(--font-display);
      font-size: 2.5rem;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin: 0 0 16px 0;
      color: var(--text-main);
    }
    .feature-card p {
      font-size: 1.125rem;
      max-width: 440px;
      color: rgba(0,0,0,0.8);
      margin: 0 0 40px 0;
    }
    .feature-snippet {
      background: var(--text-inverse);
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
      font-family: var(--font-mono);
      font-size: 14px;
      line-height: 1.6;
      color: var(--text-main);
      overflow-x: auto;
      border: 1px solid rgba(0,0,0,0.05);
    }
    .feature-snippet.dark-snippet {
      background: var(--bg-dark);
      color: var(--text-inverse);
    }

    /* ═══════════════════════════════════════════════════
       7. DARK SECTION ("Make every token count")
       ═══════════════════════════════════════════════════ */
    .dark-sec {
      background: var(--bg-dark);
      color: var(--text-inverse);
      padding: 140px 0 100px;
      text-align: center;
    }
    .dark-sec h2 {
      font-family: var(--font-display);
      font-size: clamp(3rem, 5vw, 4.5rem);
      font-weight: 700;
      letter-spacing: -0.04em;
      margin: 0 0 60px 0;
    }
    .dark-sec .italic-highlight {
      font-style: italic;
      color: var(--brand-purple);
    }
    .yellow-pill {
      background: var(--brand-yellow);
      border-radius: 200px;
      padding: 80px 40px;
      max-width: 900px;
      margin: 0 auto 80px;
      display: flex;
      justify-content: center;
    }
    .pill-content {
      background: var(--text-inverse);
      border-radius: 12px;
      padding: 32px;
      width: 100%;
      max-width: 600px;
      color: var(--text-main);
      box-shadow: 0 20px 40px rgba(0,0,0,0.2);
      text-align: left;
    }
    .pill-mock-header {
      display: flex;
      gap: 8px;
      margin-bottom: 24px;
    }
    .pill-mock-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }
    .pill-mock-dot:nth-child(1) { background: #FF5F56; }
    .pill-mock-dot:nth-child(2) { background: #FFBD2E; }
    .pill-mock-dot:nth-child(3) { background: #27C93F; }

    .dark-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 40px;
      max-width: 1000px;
      margin: 0 auto;
      border-top: 1px solid var(--border-dark);
      padding-top: 60px;
      text-align: left;
    }
    .dark-stat-val {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .dark-stat-desc {
      font-size: 14px;
      color: #999;
      line-height: 1.5;
    }

    /* ═══════════════════════════════════════════════════
       8. TESTIMONIALS (ORANGE SECTION)
       ═══════════════════════════════════════════════════ */
    .orange-sec {
      background: var(--brand-orange);
      color: var(--text-main);
      padding: 120px 0;
    }
    .orange-top {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 60px;
      margin-bottom: 100px;
    }
    .orange-top-col {
      text-align: center;
    }
    .orange-huge {
      font-family: var(--font-display);
      font-size: clamp(60px, 8vw, 100px);
      font-weight: 700;
      line-height: 1;
      border-top: 3px solid var(--text-main);
      border-bottom: 3px solid var(--text-main);
      padding: 30px 0;
      margin-bottom: 20px;
      letter-spacing: -0.04em;
    }
    .orange-label {
      font-size: 16px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .orange-quotes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 60px;
    }
    .quote-item {
      display: flex;
      flex-direction: column;
    }
    .quote-mark {
      background: var(--text-main);
      color: var(--brand-orange);
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 40px;
      font-weight: 700;
      border-radius: 8px;
      margin-bottom: 24px;
      padding-top: 8px;
    }
    .quote-text {
      font-size: 18px;
      font-weight: 500;
      line-height: 1.5;
      margin-bottom: 40px;
      flex: 1;
    }
    .quote-author {
      border-top: 2px solid var(--text-main);
      padding-top: 16px;
      font-size: 15px;
      font-weight: 700;
    }
    .quote-author span {
      display: block;
      font-weight: 500;
      opacity: 0.8;
      margin-top: 4px;
    }

    /* ═══════════════════════════════════════════════════
       9. CTA BANNER (YELLOW)
       ═══════════════════════════════════════════════════ */
    .yellow-cta {
      background: var(--brand-yellow);
      padding: 40px 0;
      border-bottom: 2px solid var(--bg-dark);
    }
    .yellow-cta .container {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .yellow-cta h3 {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 700;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }

    /* ═══════════════════════════════════════════════════
       10. MEGA FOOTER
       ═══════════════════════════════════════════════════ */
    .footer {
      background: var(--bg-dark);
      color: var(--text-inverse);
      padding: 100px 0 40px;
      overflow: hidden;
    }
    .footer-top {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 60px;
      margin-bottom: 120px;
    }
    .footer-col h4 {
      color: var(--text-muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin: 0 0 24px 0;
    }
    .footer-col ul {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .footer-col a {
      font-size: 15px;
      font-weight: 500;
      color: #CCC;
      transition: color 0.2s;
    }
    .footer-col a:hover {
      color: var(--brand-yellow);
    }
    
    .footer-mega {
      font-family: var(--font-display);
      font-size: 16.5vw;
      font-weight: 700;
      line-height: 0.8;
      letter-spacing: -0.05em;
      text-align: center;
      margin: 0 -20px;
    }
    .footer-mega span {
      color: var(--brand-yellow);
    }
    .footer-bottom {
      display: flex;
      justify-content: space-between;
      margin-top: 60px;
      font-size: 14px;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* ═══════════════════════════════════════════════════
       RESPONSIVE
       ═══════════════════════════════════════════════════ */
    @media (max-width: 1024px) {
      .hero__inner { flex-direction: column; align-items: flex-start; gap: 40px; }
      .hero__right { max-width: 100%; }
      .features__inner { flex-direction: column; gap: 60px; }
      .features__nav { position: static; width: 100%; }
      .features__nav ul { flex-direction: row; flex-wrap: wrap; gap: 20px; }
      
      .yellow-pill { padding: 40px 20px; border-radius: 40px; }
      .dark-stats { grid-template-columns: repeat(2, 1fr); }
      
      .orange-top, .orange-quotes { grid-template-columns: repeat(1, 1fr); }
      .yellow-cta .container { flex-direction: column; text-align: center; gap: 24px; }
      .footer-top { grid-template-columns: repeat(2, 1fr); gap: 40px; }
    }
    @media (max-width: 768px) {
      .nav__links { display: none; }
      .feature-card { padding: 40px 32px; min-height: auto; }
      .feature-card h3 { font-size: 2rem; }
    }
  </style>
</head>
<body>

  <!-- 1. TOP BANNER -->
  <div class="top-banner">
    OpenJCK v0.3 is live — open source visual debugger for AI agents → <span class="mono">pip install openjck</span>
  </div>

  <!-- 2. NAV -->
  <nav class="nav" id="nav">
    <div class="container nav__inner">
      <a href="/" class="nav__logo">OPENJCK.</a>
      <div class="nav__links">
        <a href="/guides/quickstart/">Docs</a>
        <a href="/reference/trace/">API</a>
        <a href="https://github.com/RavaniRoshan/openjck" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
      <div class="nav__actions">
        <a href="/guides/quickstart/" class="btn btn-dark">Get Started Free</a>
      </div>
    </div>
  </nav>

  <!-- 3. HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__left">
        <h1>
          Debug AI agents.<br/>
          <span class="hero__highlight">Fix</span> effortlessly.
        </h1>
      </div>
      <div class="hero__right">
        <p>Your agent ran 15 steps. Step 9 failed silently. OpenJCK shows you exactly what happened — every LLM call, every tool, every token.</p>
        <div class="hero__ctas">
          <a href="/guides/quickstart/" class="btn btn-dark">pip install openjck</a>
